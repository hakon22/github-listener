{
  "name": "github-listener",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx tsc && npx tsc-alias --resolve-full-paths",
    "start:app:dev": "cross-env NODE_ENV=development tsx src/main.ts",
    "start:app:prod": "cross-env NODE_ENV=production node src/main.js",
    "start:app:docker:dev": "cross-env IS_DOCKER='TRUE' NODE_ENV=development node src/main.js",
    "start:app:docker:prod": "cross-env IS_DOCKER='TRUE' NODE_ENV=production node src/main.js",
    "lint": "eslint ./src",
    "test": "jest --config ./jest.config.cjs --runInBand"
  },
  "dependencies": {
    "@gitbeaker/rest": "43.8.0",
    "@langchain/mistralai": "1.0.6",
    "@octokit/rest": "21.0.0",
    "@octokit/webhooks": "14.2.0",
    "dotenv": "17.2.3",
    "langchain": "1.2.28",
    "lodash": "4.17.21",
    "moment": "2.30.1",
    "moment-timezone": "0.6.0",
    "socks-proxy-agent": "8.0.5",
    "telegraf": "4.16.3",
    "typescript-ioc": "3.2.2",
    "winston": "3.18.3",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.1",
    "@octokit/webhooks-types": "7.0.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.21",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "cross-env": "10.1.0",
    "eslint": "9.39.1",
    "express": "4.22.1",
    "globals": "16.5.0",
    "jest": "30.2.0",
    "mime-types": "2.1.35",
    "ts-jest": "29.4.5",
    "typescript": "5.9.3"
  }
}
